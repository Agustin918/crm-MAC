generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  status    String   @default("LEAD") // LEAD, CONTACTED, QUALIFIED, WON, LOST
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  interactions Interaction[]
}

model Interaction {
  id        String   @id @default(cuid())
  type      String   // NOTE, EMAIL, CALL, MEETING
  content   String
  createdAt DateTime @default(now())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id])
}
